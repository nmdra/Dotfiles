#!/bin/sh

# File preview handler for lf (Image previews disabled).
# Supports syntax highlighting (bat), markdown (glow), aligned tables (column).

set -C -f
IFS="$(printf '%b_' '\n')"; IFS="${IFS%_}"

# Get file mime type
mime=$(file --dereference --brief --mime-type -- "$1")

# Get file extension in lowercase
ext="${1##*.}"
ext=$(printf '%s' "$ext" | tr '[:upper:]' '[:lower:]')

case "$mime" in
    image/*)
        mediainfo "$1"
        ;;
    text/html)
        lynx -width="$2" -display_charset=utf-8 -dump "$1"
        ;;
    text/troff)
        man ./ "$1" | col -b
        ;;
    *)
        case "$ext" in
            md|markdown)
                if command -v glow >/dev/null 2>&1; then
                    glow -s dark -w "$(($2-4))" "$1"
                else
                    bat --color=always --style=numbers --terminal-width="$(($2-2))" "$1"
                fi
                ;;
            csv)
                if command -v column >/dev/null 2>&1; then
                    column -s, -t < "$1" | bat --color=always --style=plain --terminal-width="$(($2-2))"
                else
                    bat --color=always --style=numbers --terminal-width="$(($2-2))" "$1"
                fi
                ;;
            *)
                case "$mime" in
                    text/* | */xml | application/json | application/javascript | application/x-shellscript)
                        bat --color=always --style=numbers --terminal-width="$(($2-2))" "$1"
                        ;;
                    application/zip | application/x-tar | application/x-bzip2 | application/x-gzip)
                        atool --list -- "$1"
                        ;;
                    audio/* | video/* | application/octet-stream)
                        mediainfo "$1" || exit 1
                        ;;
                    */pdf)
                        if command -v pdfinfo >/dev/null 2>&1; then
                            pdfinfo "$1"
                        elif command -v pdftotext >/dev/null 2>&1; then
                            pdftotext "$1" - | head -n 100
                        else
                            mediainfo "$1"
                        fi
                        ;;
                    *opendocument*)
                        odt2txt "$1"
                        ;;
                    application/pgp-encrypted)
                        gpg -d -- "$1"
                        ;;
                    *)
                        # Fallback for unknown files: try displaying as plain text via bat
                        bat --color=always --style=plain --terminal-width="$(($2-2))" "$1" || exit 1
                        ;;
                esac
                ;;
        esac
        ;;
esac
exit 1
