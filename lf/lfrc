set ignorecase true
set icons true
set preview true
set previewer '~/.config/lf/scope'

# Archive bindings
cmd unarchive ${{
 atool --extract "$f" || echo "Unsupported format"
}}

cmd mkdir ${{
  printf "Directory Name: "
  read ans
  mkdir $ans
}}

cmd mkfile ${{
  printf "File Name: "
  read ans
  nvim $ans
}}

cmd zip %zip -r "$f.zip" "$fx"
cmd tar %tar cvf "$f.tar" "$f"
cmd targz %tar cvzf "$f.tar.gz" "$f"
cmd tarbz2 %tar cjvf "$f.tar.bz2" "$f"

# Trash CLI bindings (Simplified, native multi-argument support)
cmd trash %trash-put -- $fx && notify-send "🚮 Trashing" "Selected files moved to Trash"

cmd clear_trash %trash-empty

cmd restore_trash ${{
  trash-restore
}}

# Zoxide Directory Navigation (auto-learns and jumps)
cmd z %{{
    result="$(zoxide query --exclude "$PWD" "$@" | sed 's/\\/\\\\/g;s/"/\\"/g')"
    lf -remote "send $id cd \"$result\""
}}

cmd zi ${{
    result="$(zoxide query -i | sed 's/\\/\\\\/g;s/"/\\"/g')"
    lf -remote "send $id cd \"$result\""
}}

cmd on-cd &{{
    zoxide add "$PWD"
}}

# Interactive FZF + Ripgrep Content Search
cmd fzf_search ${{
    cmd="rg --column --line-number --no-heading --color=always --smart-case"
    fzf --ansi --disabled --layout=reverse --header="Search inside files" --delimiter=: \
        --bind="start:reload([ -n {q} ] && $cmd -- {q} || true)" \
        --bind="change:reload([ -n {q} ] && $cmd -- {q} || true)" \
        --bind='enter:become(lf -remote "send $id select \"$(printf "%s" {1} | sed '\''s/\\/\\\\/g;s/"/\\"/g'\'')\"")' \
        --preview='bat --color=always --highlight-line={2} -- {1}'
}}

# FZF File Jump
cmd fzf_jump ${{
  res="$(fd -H -d 3 |sed 's@^\./@@'|fzf --reverse --prompt 'Jump to location: ')
"
  if [ -f "$res" ]; then
    cmd="select"
  elif [ -d "$res" ]; then
    cmd="cd"
  fi
  lf -remote "send $id $cmd \"$res\""
}}

# Git Integration Mappings
cmd git_branch ${{
    git branch | fzf | xargs git checkout
    pwd_shell="$(pwd | sed 's/\\/\\\\/g;s/"/\\"/g')"
    lf -remote "send $id updir; cd \"$pwd_shell\""
}}

# Remove some default maps
map m
map o
map n
map "'"
map '"'
map d
map c
map e
map f
map y

# Basic Functions
map . set hidden!
map DD delete
map Y copy
map P paste
map <esc> quit
map X cut
map <enter> open
map mf mkfile
map md mkdir
map ch chmod
map br $vimv $fx
map r rename
map H top
map L bottom
map R reload
map c clear
map U unselect
map <c-t> fzf_jump

# Zoxide Mappings
map z push :z<space>
map zi zi

# Interactive Search Mapping
map gs :fzf_search

# Git Mappings
map gb :git_branch
map gp $clear; git pull --rebase || true; echo "press ENTER"; read ENTER
map gS $clear; git status; echo "press ENTER"; read ENTER
map gl $clear; git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

# Trash Mappings
map dd trash
map tr restore_trash
